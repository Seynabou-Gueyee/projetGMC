# 🔐 EXEMPLE FICHIER .env - CHATBOT IA v3.0
# 
# Copier ce fichier en ".env" et remplir avec vos clés
# ⚠️ NE PAS COMMITER CE FICHIER SUR GIT!

# ═══════════════════════════════════════════════════════════
# ✅ CHOIX 1: OpenAI (Recommandé - GPT-4)
# ═══════════════════════════════════════════════════════════

# Obtenir clé: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXcc
OPENAI_MODEL=gpt-4-turbo

# ou pour meilleure qualité (plus cher):
# OPENAI_MODEL=gpt-4

# ou pour plus économique:
# OPENAI_MODEL=gpt-3.5-turbo

# ═══════════════════════════════════════════════════════════
# ✅ CHOIX 2: Claude (Anthropic)
# ═══════════════════════════════════════════════════════════

# Obtenir clé: https://console.anthropic.com/
# CLAUDE_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# CLAUDE_MODEL=claude-3-opus-20240229

# Autres modèles Claude:
# CLAUDE_MODEL=claude-3-sonnet-20240229      (équilibré)
# CLAUDE_MODEL=claude-3-haiku-20240307       (rapide)

# ═══════════════════════════════════════════════════════════
# ✅ CHOIX 3: Gemini (Google - Gratuit!)
# ═══════════════════════════════════════════════════════════

# Obtenir clé: https://ai.google.dev/
# Get API Key → Create free key
# GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# GEMINI_MODEL=gemini-pro

# ═══════════════════════════════════════════════════════════
# ✅ CHOIX 4: Ollama (Local - Totalement Gratuit!)
# ═══════════════════════════════════════════════════════════

# Installation: https://ollama.ai
# Après installation, dans terminal:
#   ollama serve (dans une fenêtre)
#   ollama pull neural-chat (dans autre fenêtre)

# Après ça, activer:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=neural-chat

# Autres modèles Ollama:
# OLLAMA_MODEL=mistral          (excellent)
# OLLAMA_MODEL=codellama        (pour coding)
# OLLAMA_MODEL=phi              (ultra-optimisé)

# ═══════════════════════════════════════════════════════════
# 🎯 CONFIGURATION PRINCIPALE
# ═══════════════════════════════════════════════════════════

# Provider principal (quel provider utiliser en premier)
# Options: openai, claude, gemini, ollama
AI_PRIMARY_PROVIDER=openai

# SI VOUS AVEZ PLUSIEURS CLÉS, configurer fallbacks:
# Si OpenAI échoue → try Claude
# Si Claude échoue → try Gemini  
# Tous échouent → fallback Ollama local (toujours gratuit!)

# ═══════════════════════════════════════════════════════════
# ⚙️ CONFIGURATION ADVANCED AI
# ═══════════════════════════════════════════════════════════

# Features
USE_RAG=true                    # Enrichissement contexte
USE_REASONING=true             # Raisonnement approfondi
USE_TOOLS=true                 # Tool execution
USE_MEMORY=true                # Conversation memory
USE_VISION=false               # Vision (images) - bientôt

# Context window
CONTEXT_WINDOW=8000            # Combien messages retenir

# Performance
CACHE_RESPONSES=true           # Cache réponses identiques
MAX_RETRIES=3                  # Retry sur erreur
REQUEST_TIMEOUT=30000          # 30 secondes timeout

# ═══════════════════════════════════════════════════════════
# 🔒 SÉCURITÉ & MODÉRATION
# ═══════════════════════════════════════════════════════════

CONTENT_FILTER=true            # Filtrer contenu dangereux
RATE_LIMIT=true                # 60 req/min par user
LOG_REQUESTS=false             # Ne pas log requests (confidentialité)
LOG_ERRORS=true                # Log erreurs

# ═══════════════════════════════════════════════════════════
# 📊 DATABASE & STORAGE
# ═══════════════════════════════════════════════════════════

MONGODB_URI=mongodb://localhost:27017/talkme
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════
# 🌳 ENVIRONMENT
# ═══════════════════════════════════════════════════════════

NODE_ENV=production            # development, production
PORT=3000
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════
# 🎁 BONUS: Variables optionnelles
# ═══════════════════════════════════════════════════════════

# Pour recherche web
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Pour vision (analyser images)
VISION_API_KEY=

# Pour speech (parler/écouter)
SPEECH_API_KEY=

# Pour traduction
TRANSLATION_API_KEY=

# ═══════════════════════════════════════════════════════════
# ✅ INSTRUCTIONS D'UTILISATION
# ═══════════════════════════════════════════════════════════

# 1. COPIER CE FICHIER:
#    cp .env.example .env

# 2. REMPLIR LES CLÉ (choisir au moins une):

# OPTION A: Utiliser OpenAI (Meilleur ratio coût/perf)
#   - Aller sur https://openai.com
#   - Créer compte → API keys
#   - Copier clé dans OPENAI_API_KEY=

# OPTION B: Utiliser Claude (Très intelligent)
#   - Aller sur https://console.anthropic.com/
#   - Créer clé API
#   - Copier dans CLAUDE_API_KEY=

# OPTION C: Utiliser Gemini (Gratuit!)
#   - Aller sur https://ai.google.dev/
#   - Get API Key
#   - Copier dans GEMINI_API_KEY=

# OPTION D: Utiliser Ollama (Totalement gratuit, local!)
#   - Installer https://ollama.ai
#   - ollama serve (terminal 1)
#   - ollama pull neural-chat (terminal 2)
#   - Set: OLLAMA_BASE_URL=http://localhost:11434

# 3. REDÉMARRER SERVEUR:
#    npm start

# 4. TESTER:
#    curl -X POST http://localhost:3000/api/chat \
#      -H "Content-Type: application/json" \
#      -d '{"message":"Explique quantum computing"}'

# ═══════════════════════════════════════════════════════════
# 🚀 PRÊT! Votre IA est maintenant au niveau ChatGPT!
# ═══════════════════════════════════════════════════════════
