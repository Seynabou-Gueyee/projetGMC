PORT=5000
MONGODB_URI=mongodb+srv://talkme_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/talkme?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_change_this_in_production
NODE_ENV=development
# ===== IA ET CHATBOT =====
# Si vous avez une clé OpenAI, le chatbot utilisera GPT pour les réponses intelligentes
# Sinon, il utilisera les réponses locales intelligentes par défaut
OPENAI_API_KEY=sk-your_openai_api_key_here

# Modèle d'IA à utiliser (gpt-3.5-turbo, gpt-4, etc.)
AI_MODEL=gpt-3.5-turbo

# Provider d'IA (openai ou local)
AI_PROVIDER=openai

# Clé d'encryption pour les messages
ENCRYPTION_KEY=your_encryption_key_here